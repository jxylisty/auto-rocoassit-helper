# ========================================
.tmp/
*.tmp
*.temp
*.log
*.bak

# ========================================
# 运行时截图（高频生成，禁止提交）
# ========================================
capture_*.png
capture_*.jpg
screenshot_*.png
screenshot_*.jpg

# 截图输出目录
data/capture_test/
data/captures/
captures/
screenshots/

# 任何位置的临时图片（排除模板）
*.png
*.jpg
*.jpeg
*.bmp
!data/templates/**/*.png
!data/templates/**/*.jpg
!docs/**/*.png
!docs/**/*.jpg
!data/vision/elements/*.png
!data/vision/exports/*.png

# ========================================
# 模型文件（通常体积大）
# ========================================
*.pt
*.pth
*.onnx
*.weights
!data/models/.gitkeep

# ========================================
# 系统文件
# ========================================
.DS_Store
Thumbs.db
desktop.ini

# ========================================
